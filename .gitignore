**/blockmgr-*/
**/blockmgr-*/**/*
**/shuffle_*.data

############################
# Data (keep directory structure, ignore contents)
############################
# Common practice: keep empty dirs tracked via .gitkeep
data/**
!data/**/.gitkeep
!data/README.md

# If you keep some small reference data in repo, whitelist it here, e.g.:
# !data/00_reference/**
# !data/00_reference/**/*
# (add as needed)

############################
# Model artifacts & outputs
############################
# Pickles / numpy arrays often contain models or large intermediates
*.pkl
*.pth
*.pt
*.npz
*.npy
*.sav

# Predictions / generated artifacts (you had mdl_churn_predicted, etc.)
data/07_model_output/
data/**/model_output/
data/**/predict/
data/**/predictions/
data/**/outputs/

